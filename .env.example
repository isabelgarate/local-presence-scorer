# ─── Google Places API (New) ────────────────────────────────────────────────
# Get your key at: https://console.cloud.google.com/
# Enable: "Places API (New)" — NOT the legacy Places API
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# ─── RapidAPI — Social Media Scrapers ───────────────────────────────────────
# One key is used for all three platforms (Instagram, Facebook, TikTok)
# Instagram: instagram-api-fast-reliable-data-scraper
# Facebook:  facebook-pages-scraper
# TikTok:    tiktok-scraper7
# https://rapidapi.com
RAPIDAPI_KEY=your_rapidapi_key_here

# ─── Scoring tuning ──────────────────────────────────────────────────────────
# Review count at which normalized score = 1.0 (log scale)
REVIEW_CAP=500
# Follower count at which normalized social score = 1.0 (log scale)
FOLLOWER_CAP=100000

# ─── Rate limiting (requests per second) ─────────────────────────────────────
GOOGLE_RATE_LIMIT=10.0
INSTAGRAM_RATE_LIMIT=2.0

# ─── App ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
